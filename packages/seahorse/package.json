{
  "name": "@drakkar.software/seahorse",
  "version": "0.3.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/Drakkar-Software/seahorse.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "Generic UI components and utilities for React Native / Expo apps — SeaHorse",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./utils/secure-store": {
      "types": "./dist/utils/secure-store.d.ts",
      "import": "./dist/utils/secure-store.js"
    },
    "./utils/kv-storage": {
      "types": "./dist/utils/kv-storage.d.ts",
      "import": "./dist/utils/kv-storage.js"
    },
    "./utils/crypto": {
      "types": "./dist/utils/crypto.d.ts",
      "import": "./dist/utils/crypto.js"
    },
    "./utils/app-lock": {
      "types": "./dist/utils/app-lock.d.ts",
      "import": "./dist/utils/app-lock.js"
    },
    "./utils/pwa-install": {
      "types": "./dist/utils/pwa-install.d.ts",
      "import": "./dist/utils/pwa-install.js"
    },
    "./utils/toast": {
      "types": "./dist/utils/toast/sonner.d.ts",
      "import": "./dist/utils/toast/sonner.js"
    },
    "./utils/file-export": {
      "types": "./dist/utils/file-export.d.ts",
      "import": "./dist/utils/file-export.js"
    },
    "./utils/links": {
      "types": "./dist/utils/links.d.ts",
      "import": "./dist/utils/links.js"
    },
    "./utils/date": {
      "types": "./dist/utils/date.d.ts",
      "import": "./dist/utils/date.js"
    },
    "./utils/ota-update": {
      "types": "./dist/utils/ota-update.d.ts",
      "import": "./dist/utils/ota-update.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    },
    "./tailwind-preset": {
      "require": "./tailwind/preset.js",
      "import": "./tailwind/preset.js"
    },
    "./tailwind-theme": {
      "style": "./tailwind/theme.css",
      "import": "./tailwind/theme.css"
    },
    "./utils/cn": {
      "types": "./dist/utils/cn.d.ts",
      "import": "./dist/utils/cn.js"
    }
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "tailwind-merge": "^3.0.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.83.0",
    "nativewind": ">=5.0.0-0",
    "react-native-css": ">=3.0.0-0",
    "lucide-react-native": ">=0.400.0",
    "@gorhom/bottom-sheet": ">=5.0.0",
    "date-fns": ">=3.0.0",
    "expo-secure-store": ">=13.0.0",
    "expo-local-authentication": ">=14.0.0",
    "expo-sqlite": ">=14.0.0",
    "@react-native-async-storage/async-storage": ">=2.0.0",
    "expo-file-system": ">=17.0.0",
    "expo-sharing": ">=12.0.0",
    "expo-print": ">=13.0.0",
    "expo-document-picker": ">=12.0.0",
    "sonner": ">=2.0.0",
    "sonner-native": ">=0.20.0",
    "expo-updates": ">=0.25.0",
    "@expo/html-elements": ">=55.0.0",
    "react-native-svg": ">=15.0.0",
    "expo-haptics": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "@gorhom/bottom-sheet": { "optional": true },
    "date-fns": { "optional": true },
    "expo-secure-store": { "optional": true },
    "expo-local-authentication": { "optional": true },
    "expo-sqlite": { "optional": true },
    "@react-native-async-storage/async-storage": { "optional": true },
    "expo-file-system": { "optional": true },
    "expo-sharing": { "optional": true },
    "expo-print": { "optional": true },
    "expo-document-picker": { "optional": true },
    "sonner": { "optional": true },
    "sonner-native": { "optional": true },
    "expo-updates": { "optional": true },
    "@expo/html-elements": { "optional": true },
    "react-native-svg": { "optional": true },
    "expo-haptics": { "optional": true },
    "react-native-css": { "optional": true }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "date-fns": "^3.6.0"
  },
  "files": [
    "dist",
    "tailwind"
  ]
}
