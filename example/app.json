{
  "expo": {
    "name": "SeaHorse Example",
    "slug": "seahorse-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "seahorse-example",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "software.drakkar.seahorse.example"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "software.drakkar.seahorse.example"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
